{
	"version": 1,
	"hooks": {
		"beforeShellExecution": [
			{
				"command": ".cursor/hooks/enforce-devenv.sh",
				"timeout": 5
			}
		],
		"afterFileEdit": [
			{
				"command": ".cursor/hooks/format-after-edit.sh",
				"timeout": 30
			}
		],
		"preToolUse": [
			{
				"command": ".cursor/hooks/block-native-web-search.sh",
				"matcher": "WebSearch|WebFetch",
				"timeout": 5
			},
			{
				"command": ".cursor/hooks/block-native-read-search.sh",
				"matcher": "Read|Grep",
				"timeout": 5
			},
			{
				"command": ".cursor/hooks/block-native-code-search.sh",
				"matcher": "SemanticSearch",
				"timeout": 5
			}
		]
	}
}
