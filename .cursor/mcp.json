{
	"mcpServers": {
		"context7": {
			"command": "bunx",
			"args": ["@upstash/context7-mcp@latest"],
			"disabled": false
		},
		"figma-mcp-go": {
			"command": "bunx",
			"args": ["@vkhanhqui/figma-mcp-go"],
			"disabled": false,
			"description": "Figma via plugin bridge (https://github.com/vkhanhqui/figma-mcp-go) \u2014 run the companion plugin in Figma Desktop"
		},
		"mcp-debugger": {
			"command": "bunx",
			"args": [
				"@debugmcp/mcp-debugger",
				"stdio",
				"--log-level",
				"debug",
				"--log-file",
				"./tmp/debug-mcp-server.log"
			],
			"disabled": false,
			"autoApprove": ["create_debug_session", "set_breakpoint", "get_variables"]
		},
		"playwright": {
			"command": "bunx",
			"args": ["@playwright/mcp@latest"],
			"disabled": false
		},
		"github": {
			"command": "bunx",
			"args": ["@modelcontextprotocol/server-github@latest"],
			"disabled": false
		},
		"chrome-devtools": {
			"command": "bunx",
			"args": ["chrome-devtools-mcp@latest"]
		},
		"postgres": {
			"command": "bun",
			"args": ["run", "apps/risk-calculator/scripts/run-postgres-mcp.ts"],
			"disabled": false
		},
		"temporal": {
			"command": "uvx",
			"args": [
				"temporal-mcp-server",
				"--host",
				"127.0.0.1:7233",
				"--namespace",
				"default",
				"--tls-enabled",
				"false"
			],
			"disabled": false,
			"description": "Temporal workflows/schedules via MCP (temporal-mcp-server; see https://github.com/GethosTheWalrus/temporal-mcp)"
		},
		"maestro": {
			"command": "maestro",
			"args": ["mcp", "serve"],
			"disabled": false,
			"description": "Maestro MCP via stdio (`maestro mcp serve`; see https://github.com/ReinaMacCredy/maestro#mcp-server)"
		},
		"lean-ctx": {
			"command": "./.devenv/profile/bin/lean-ctx",
			"args": [],
			"disabled": false,
			"description": "lean-ctx MCP (context compression); run devenv shell once so .devenv/profile exists"
		},
		"serena": {
			"type": "stdio",
			"command": "./.devenv/state/venv/bin/serena",
			"args": ["start-mcp-server"],
			"disabled": false,
			"description": "Serena MCP (@oraios/serena); run devenv shell once so .devenv/state/venv exists"
		},
		"roam-code": {
			"type": "stdio",
			"command": "./.devenv/profile/bin/roam",
			"args": ["mcp"],
			"disabled": false,
			"description": "roam-code MCP (fastmcp); run devenv shell once so .devenv/profile exists"
		},
		"searxng": {
			"command": "bunx",
			"args": ["mcp-searxng"],
			"env": {
				"SEARXNG_URL": "http://localhost:4001"
			},
			"disabled": false,
			"description": "Web search via local SearXNG at http://localhost:4001 (mcp-searxng)"
		},
		"definitively": {
			"command": "./definitively/definitively",
			"args": ["mcp", "serve"],
			"disabled": false,
			"env": {
				"DEFINITIVELY_WORKSPACE": "${workspaceFolder}",
				"DEFINITIVELY_LOG_LEVEL": "WARN"
			},
			"description": "Definitively workflow MCP (stdio via in-repo escript)"
		}
	}
}
